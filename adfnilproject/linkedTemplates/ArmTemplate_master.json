{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adfnilproject"
		},
		"LS_ADLS_Healthcare_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_ADLS_Healthcare'"
		},
		"LS_SQLServer_Healthcare_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_SQLServer_Healthcare'"
		},
		"LS_ADLS_Healthcare_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://scnilproject.dfs.core.windows.net/"
		},
		"LS_SQLServer_Healthcare_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "NIL\\SQLEXPRESS01"
		},
		"LS_SQLServer_Healthcare_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "HealthcareDB"
		},
		"LS_SQLServer_Healthcare_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "adf_user"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adfnilproject_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_ADLS_Healthcare_accountKey": {
						"value": "[parameters('LS_ADLS_Healthcare_accountKey')]"
					},
					"LS_SQLServer_Healthcare_password": {
						"value": "[parameters('LS_SQLServer_Healthcare_password')]"
					},
					"LS_ADLS_Healthcare_properties_typeProperties_url": {
						"value": "[parameters('LS_ADLS_Healthcare_properties_typeProperties_url')]"
					},
					"LS_SQLServer_Healthcare_properties_typeProperties_server": {
						"value": "[parameters('LS_SQLServer_Healthcare_properties_typeProperties_server')]"
					},
					"LS_SQLServer_Healthcare_properties_typeProperties_database": {
						"value": "[parameters('LS_SQLServer_Healthcare_properties_typeProperties_database')]"
					},
					"LS_SQLServer_Healthcare_properties_typeProperties_userName": {
						"value": "[parameters('LS_SQLServer_Healthcare_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}